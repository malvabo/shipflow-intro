{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git push*)",
            "command": "npx vercel --prod 2>&1",
            "statusMessage": "Deploying to Vercel..."
          }
        ]
      }
    ]
  }
}
